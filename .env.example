# Domains (used by Traefik for TLS certificates)
PANEL_DOMAIN=panel.example.com
WINGS_DOMAIN=wings.example.com
ACME_EMAIL=admin@example.com

# PostgreSQL
POSTGRES_USER=petrel
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=petrel

# Panel
BETTER_AUTH_SECRET=generate-a-64-char-random-string
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
ADMIN_EMAILS=admin@example.com

# Wings (must match token in wings-config.yml)
WINGS_TOKEN=generate-another-secure-random-string
